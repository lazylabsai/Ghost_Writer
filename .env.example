# LLM Providers
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here

# Speech-to-Text Providers
GROQ_STT_API_KEY=your_groq_stt_api_key_here
OPENAI_STT_API_KEY=your_openai_stt_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
AZURE_API_KEY=your_azure_api_key_here
AZURE_REGION=your_azure_region_here
IBMWATSON_API_KEY=your_ibmwatson_api_key_here
IBMWATSON_REGION=your_ibmwatson_region_here

# Audio Configuration
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Local Ollama URL (Default is http://localhost:11434)
OLLAMA_API_URL=http://localhost:11434

# Development
NODE_ENV=development
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn_here # Optional
